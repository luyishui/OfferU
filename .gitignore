# =============================================
# OfferU — Git 忽略规则
# =============================================

# ---- 依赖目录 ----
node_modules/
.venv/
__pycache__/
*.pyc

# ---- 构建输出 ----
frontend/.next/
frontend/out/
backend/*.db
*.db

# ---- 环境配置 ----
.env
.env.local
.env.*.local
backend/config.json

# ---- IDE / 编辑器 ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- OS 文件 ----
.DS_Store
Thumbs.db
desktop.ini

# ---- 上传目录中的用户文件 ----
backend/uploads/photos/*
!backend/uploads/photos/.gitkeep

# ---- 日志 ----
*.log
npm-debug.log*

# ---- 测试/临时 ----
coverage/
.pytest_cache/
