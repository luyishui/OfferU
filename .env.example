# =============================================
# OfferU - 环境变量模板
# =============================================
# 复制此文件为 .env 并填写实际值
# cp .env.example .env
# =============================================

# ---- 数据库 ----
DB_USER=offeru
DB_PASSWORD=offeru_secret
DB_NAME=offeru
OFFERU_DATA_DIR=

# ---- API Keys ----
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
APIFY_API_KEY=

# ---- AI 模型配置 ----
LLM_PROVIDER=qwen
LLM_MODEL=qwen-flash

# ---- 网络（使用 Clash/V2Ray 代理时需要） ----
# 国内 API（百炼）需要绕过代理直连
NO_PROXY=dashscope.aliyuncs.com,cn-beijing.maas.aliyuncs.com

# ---- 安全 ----
SECRET_KEY=change-me-to-a-random-string-in-production

# ---- Gmail OAuth (邮件面试通知) ----
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=

# ---- 前端跨域 ----
CORS_ORIGINS=http://localhost:3011,http://127.0.0.1:3011,http://localhost:3000,http://127.0.0.1:3000

# ---- 数据库连接串（后端用，Docker 模式自动拼接） ----
DATABASE_URL=
